# ============================================================
#  MindOS — Variáveis de Ambiente
#  Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Supabase (obrigatório para autenticação e sync)
# Obtenha em: supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Anthropic — Coach IA (opcional)
# Obtenha em: console.anthropic.com/settings/keys
EXPO_PUBLIC_ANTHROPIC_KEY=sua_chave_aqui

# Redirect para reset de senha (opcional, só para web)
EXPO_PUBLIC_AUTH_REDIRECT_URL=
